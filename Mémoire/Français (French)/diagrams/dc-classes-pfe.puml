@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #EEF5FF
  BorderColor #3366CC
  ArrowColor #3366CC
  FontSize 11
}

skinparam class<<acteur>> {
  BackgroundColor #FFF8E1
  BorderColor #FF8C00
}

enum TypeGroupement {
  monome
  binome
  trinome
}

enum StatutSujet {
  en_attente
  valide
  accepte_sous_reserve
  refuse
  expire
}

enum DecisionValidateur {
  valide
  accepte_sous_reserve
  refuse
}

enum StatutAffectation {
  en_cours
  memoire_soumis
  soutenance_planifiee
  valide
  refuse
}

enum ResultatSoutenance {
  admis
  corrections_requises
  non_admis
}

class Etudiant <<acteur>> {
  +consulterCatalogue()
  +exprimerVoeu(sujet)
  +supprimerVoeu(voeu)
  +soumettreMemoire(fichier)
  +consulterResultats()
}

class Enseignant <<acteur>> {
  +proposerSujet(sujet)
  +validerSujet(decision)
  +ajouterFicheSuivi(reunion)
  +soumettreEvaluation(note)
  +confirmerJury()
  +soumettreNotesJury(notes)
}

class Entreprise <<acteur>> {
  +proposerSujet(sujet)
  +accepterCandidat(etudiant)
  +soumettreEvaluation(note)
}

class SujetPFE {
  +id: String
  +titre: String
  +description: String
  +typeGroupement: TypeGroupement
  +roleProposant: String
  +statut: StatutSujet
  +decisionValidateur1: DecisionValidateur
  +commentaireValidateur1: String
  +decisionValidateur2: DecisionValidateur
  +commentaireValidateur2: String
}

class Voeu {
  +id: String
  +statut: String
  +dateCreation: DateTime
}

class AffectationPFE {
  +id: String
  +codePFE: String
  +urlMemoire: String
  +statut: StatutAffectation
}

class FicheSuivi {
  +id: String
  +dateReunion: Date
  +duree: Integer
  +typeReunion: String
  +sujetsAbordes: String
  +observation: String
  +statut: String
}

class JurySoutenance {
  +id: String
  +presidentConfirme: Boolean
  +membreConfirme: Boolean
}

class Soutenance {
  +id: String
  +datePrevue: DateTime
  +salle: String
  +echeance: Date
  +statut: String
  +resultat: ResultatSoutenance
  +noteFinale: Float
}

class NoteJury {
  +id: String
  +critere1: Float
  +critere2: Float
  +critere3: Float
  +critere4: Float
}

class EvaluationEncadrant {
  +id: String
  +critere5: Float
}

class Domaine <<acteur>> {
}

class AnneeAcademique <<acteur>> {
}

SujetPFE "0..*" --> "1" AnneeAcademique
SujetPFE "0..*" -- "0..*" Domaine
SujetPFE "0..*" --> "1" Enseignant : proposé / validé par
SujetPFE "0..*" --> "0..1" Entreprise : proposé par

Voeu "0..*" --> "1" Etudiant
Voeu "0..*" --> "1" SujetPFE

AffectationPFE "0..*" --> "1" SujetPFE
AffectationPFE "1" --> "1..3" Etudiant
AffectationPFE "0..*" --> "1" Enseignant : superviseur

FicheSuivi "0..*" --> "1" AffectationPFE

JurySoutenance "1" --> "1" AffectationPFE
JurySoutenance "0..*" --> "1" Enseignant : président / membre

Soutenance "1" --> "1" AffectationPFE
Soutenance "0..*" --> "1" JurySoutenance

NoteJury "0..*" --> "1" Soutenance
NoteJury "0..*" --> "1" Enseignant : évaluateur

EvaluationEncadrant "1" --> "1" AffectationPFE
EvaluationEncadrant "0..*" --> "1" Enseignant : évaluateur

note bottom of Etudiant : Attributs détaillés dans\nle diagramme des acteurs
@enduml
