@startuml
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #EEF5FF
  BorderColor #3366CC
  ArrowColor #3366CC
}

actor "Entreprise" as C

rectangle "Système de Gestion des PFE" {
  usecase "S'authentifier" as AUTH
  usecase "Proposer un sujet PFE" as UC1
  usecase "Consulter les\ncandidatures" as UC2
  usecase "Suivre les PFE\nassignés" as UC3
  usecase "Participer au suivi\npédagogique" as UC4
  usecase "Soumettre un rapport\nde correction" as UC6
}

C --> UC1
C --> UC2
C --> UC3
C --> UC4
C --> UC6

UC1 ..> AUTH : <<include>>
UC2 ..> AUTH : <<include>>
UC3 ..> AUTH : <<include>>
UC4 ..> AUTH : <<include>>
UC6 ..> AUTH : <<include>>

UC2 ..> UC1 : <<extend>>
@enduml
