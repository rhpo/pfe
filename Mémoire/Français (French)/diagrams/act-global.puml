@startuml
skinparam activity {
  BackgroundColor #EEF5FF
  BorderColor #3366CC
  ArrowColor #3366CC
  DiamondBackgroundColor #FFF8E1
  DiamondBorderColor #FF8C00
  FontSize 12
}

|Enseignant / Entreprise|
start
:Proposer un sujet PFE;

|Administration|
:Assigner les validateurs;

|Enseignant / Entreprise|
:Évaluer le sujet\n(en tant que validateur);
if (Sujet validé ?) then (Oui)
else (Non)
  :Notifier le proposant\n(sujet refusé);
  stop
endif

|Administration|
:Publier le sujet au catalogue;

|Étudiant|
:Consulter le catalogue;
:Exprimer ses vœux\n(classés par préférence);

|Enseignant / Entreprise|
:Consulter les candidatures;
:Accepter ou refuser\nles candidats;

|Administration|
:Procéder aux affectations PFE;
:Générer le code PFE;
:Affecter superviseur\net co-superviseur;
:Notifier toutes les parties;

|Étudiant|
:Réaliser les travaux du PFE;

fork
  |Étudiant|
  :Participer aux\nréunions de suivi;
|Enseignant / Entreprise|
  :Renseigner les\nfiches de suivi;
fork end

|Étudiant|
:Soumettre le mémoire final;

|Administration|
:Constituer le jury\n(président + membre);
:Planifier la soutenance\n(date, salle);
:Notifier toutes les parties;

|Étudiant|
:Présenter la soutenance;

|Enseignant / Entreprise|
:Soumettre les notes du jury\n(critères 1 à 4);
:Soumettre l'évaluation\nde l'encadrant (critère 5);

|Administration|
:Calculer la note finale (/20);

if (Résultat ?) then (Admis)
  :Archiver et publier le PFE;
  stop
else if (Corrections requises)
  |Étudiant|
  :Apporter les corrections;
  :Re-soumettre le mémoire;
  |Administration|
  :Re-planifier la soutenance;
else (Non admis)
  stop
endif
@enduml
