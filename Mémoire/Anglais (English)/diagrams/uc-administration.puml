@startuml
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #EEF5FF
  BorderColor #3366CC
  ArrowColor #3366CC
}

actor "Administration" as A

rectangle "PFE Management System" {
  usecase "Authenticate" as AUTH
  usecase "Manage users" as UC1
  usecase "Validate partner\ncompanies" as UC2
  usecase "Assign validators\nto topics" as UC3
  usecase "Carry out\nPFE assignments" as UC4
  usecase "Form defence\njuries" as UC5
  usecase "Schedule\ndefences" as UC6
  usecase "Manage academic\nparameters" as UC8
  usecase "Consult statistics\nand export reports" as UC9
}

A --> UC1
A --> UC2
A --> UC3
A --> UC4
A --> UC5
A --> UC6
A --> UC8
A --> UC9

UC1 ..> AUTH : <<include>>
UC2 ..> AUTH : <<include>>
UC3 ..> AUTH : <<include>>
UC4 ..> AUTH : <<include>>
UC5 ..> AUTH : <<include>>
UC6 ..> AUTH : <<include>>
UC8 ..> AUTH : <<include>>
UC9 ..> AUTH : <<include>>

UC6 ..> UC5 : <<include>>
UC4 ..> UC3 : <<include>>
@enduml
