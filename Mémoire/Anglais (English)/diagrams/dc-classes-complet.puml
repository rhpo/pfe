@startuml
scale 1.5
left to right direction
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #EEF5FF
  BorderColor #3366CC
  ArrowColor #3366CC
  FontSize 10
}

' === ENUMS ===
enum UserRole {
  student
  lecturer
  admin
  company
}

enum LecturerGrade {
  assistant
  mab
  maa
  mcb
  mca
  professor
}

enum GroupType {
  individual
  pair
  trio
}

enum TopicStatus {
  pending
  validated
  conditionally_accepted
  rejected
}

enum ValidatorDecision {
  validated
  conditionally_accepted
  rejected
}

enum AssignmentStatus {
  in_progress
  thesis_submitted
  defence_scheduled
  validated
  rejected
}

enum DefenceResult {
  admitted
  corrections_required
  not_admitted
}

' === ACTORS ===
class UserProfile {
  +id: String
  +role: UserRole
  +fullName: String
  +email: String
  +avatarUrl: String
  +isActive: Boolean
  +createdAt: DateTime
  --
  +authenticate()
}

class Student {
  +id: String
  +studentNumber: String
  +level: String
  --
  +browseCatalogue()
  +submitPreference(subject)
  +submitThesis(file)
}

class Lecturer {
  +id: String
  +grade: LecturerGrade
  +department: String
  +availabilityStatus: String
  +unavailableUntil: Date
  --
  +proposeTopic(subject)
  +validateTopic(decision)
  +submitEvaluation(grade)
  +confirmJury()
  +submitJuryGrades(grades)
}

class Company {
  +id: String
  +companyName: String
  +sector: String
  +description: String
  +contactEmail: String
  +contactPhone: String
  +isVerified: Boolean
  --
  +proposeTopic(subject)
}

' === ACADEMIC CONTEXT ===
class AcademicYear {
  +id: String
  +label: String
  +status: String
  +submissionOpen: DateTime
  +submissionClose: DateTime
  +maxPreferences: Integer
}

class Cohort {
  +id: String
  +label: String
}

class Specialisation {
  +id: String
  +name: String
  +code: String
  +yearType: String
}

class Domain {
  +id: String
  +name: String
}

' === TOPICS AND PREFERENCES ===
class PFETopic {
  +id: String
  +title: String
  +description: String
  +groupType: GroupType
  +proposerRole: String
  +status: TopicStatus
  +validator1Decision: ValidatorDecision
  +validator1Comment: String
  +validator2Decision: ValidatorDecision
  +validator2Comment: String
}

class Preference {
  +id: String
  +status: String
  +createdAt: DateTime
}

' === ASSIGNMENT AND SUPERVISION ===
class PFEAssignment {
  +id: String
  +pfeCode: String
  +thesisUrl: String
  +status: AssignmentStatus
}

class ProgressReport {
  +id: String
  +meetingDate: Date
  +duration: Integer
  +meetingType: String
  +topicsDiscussed: String
  +observation: String
  +status: String
}

' === EVALUATION AND DEFENCE ===
class DefenceJury {
  +id: String
  +presidentConfirmed: Boolean
  +memberConfirmed: Boolean
}

class Defence {
  +id: String
  +scheduledAt: DateTime
  +room: String
  +deadline: Date
  +status: String
  +result: DefenceResult
  +finalGrade: Float
}

class JuryGrade {
  +id: String
  +criterion1: Float
  +criterion2: Float
  +criterion3: Float
  +criterion4: Float
}

class SupervisorEvaluation {
  +id: String
  +criterion5: Float
}

' === RELATIONS ===
UserProfile <|-- Student
UserProfile <|-- Lecturer
UserProfile <|-- Company

Student "0..*" --> "1" Specialisation : belongs to
Student "0..*" --> "1" Cohort : enrolled in
Cohort "0..*" --> "1" AcademicYear : attached to
Lecturer "0..*" -- "0..*" Domain : expertise in

PFETopic "0..*" --> "1" AcademicYear
PFETopic "0..*" -- "0..*" Domain
PFETopic "0..*" --> "1" Lecturer : proposed / validated by
PFETopic "0..*" --> "0..1" Company : proposed by

Preference "0..*" --> "1" Student
Preference "0..*" --> "1" PFETopic

PFEAssignment "0..*" --> "1" PFETopic
PFEAssignment "1" --> "1..3" Student
PFEAssignment "0..*" --> "1" Lecturer : supervisor

ProgressReport "0..*" --> "1" PFEAssignment

DefenceJury "1" --> "1" PFEAssignment
DefenceJury "0..*" --> "1" Lecturer : president / member

Defence "1" --> "1" PFEAssignment
Defence "0..*" --> "1" DefenceJury

JuryGrade "0..*" --> "1" Defence
JuryGrade "0..*" --> "1" Lecturer : evaluator

SupervisorEvaluation "1" --> "1" PFEAssignment
SupervisorEvaluation "0..*" --> "1" Lecturer : evaluator
@enduml
