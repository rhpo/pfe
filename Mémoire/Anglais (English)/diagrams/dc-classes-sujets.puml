@startuml
left to right direction
skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #EEF5FF
  BorderColor #3366CC
  ArrowColor #3366CC
  FontSize 11
}

skinparam class<<acteur>> {
  BackgroundColor #FFF8E1
  BorderColor #FF8C00
}

enum TypeGroupement {
  monome
  binome
  trinome
}

enum StatutSujet {
  en_attente
  valide
  accepte_sous_reserve
  refuse
  expire
}

enum DecisionValidateur {
  valide
  accepte_sous_reserve
  refuse
}

enum StatutAffectation {
  en_cours
  memoire_soumis
  soutenance_planifiee
  valide
  refuse
}

class Etudiant <<acteur>> {
  +consulterCatalogue()
  +exprimerVoeu(sujet)
  +supprimerVoeu(voeu)
  +soumettreMemoire(fichier)
}

class Enseignant <<acteur>> {
  +proposerSujet(sujet)
  +validerSujet(decision)
}

class Entreprise <<acteur>> {
  +proposerSujet(sujet)
  +accepterCandidat(etudiant)
}

class Domaine <<acteur>> {
}

class AnneeAcademique <<acteur>> {
}

class SujetPFE {
  +id: String
  +titre: String
  +description: String
  +typeGroupement: TypeGroupement
  +roleProposant: String
  +statut: StatutSujet
  +decisionValidateur1: DecisionValidateur
  +commentaireValidateur1: String
  +decisionValidateur2: DecisionValidateur
  +commentaireValidateur2: String
}

class Voeu {
  +id: String
  +statut: String
  +dateCreation: DateTime
}

class AffectationPFE {
  +id: String
  +codePFE: String
  +urlMemoire: String
  +statut: StatutAffectation
}

class FicheSuivi {
  +id: String
  +dateReunion: Date
  +duree: Integer
  +typeReunion: String
  +sujetsAbordes: String
  +observation: String
  +statut: String
}

SujetPFE "0..*" --> "1" AnneeAcademique
SujetPFE "0..*" -- "0..*" Domaine
SujetPFE "0..*" --> "1" Enseignant : proposé / validé par
SujetPFE "0..*" --> "0..1" Entreprise : proposé par

Voeu "0..*" --> "1" Etudiant
Voeu "0..*" --> "1" SujetPFE

AffectationPFE "0..*" --> "1" SujetPFE
AffectationPFE "1" --> "1..3" Etudiant
AffectationPFE "0..*" --> "1" Enseignant : superviseur

FicheSuivi "0..*" --> "1" AffectationPFE

note bottom of Etudiant : Attributs détaillés dans\nle diagramme des acteurs
@enduml
