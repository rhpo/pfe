@startuml
scale 1.0
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBackgroundColor #EEF5FF
skinparam sequenceParticipantBorderColor #3366CC

actor "Lecturer\n(Jury Member)" as J
actor "Lecturer\n(Supervisor)" as Sup
participant "System" as S
database "DBMS" as DB

J -> S : Submits grades\n(criteria 1 to 4, each out of 4)
activate S
S -> S : Validates grades\n(each criterion between 0 and 4)
S -> DB : INSERT INTO jury_grades\n(defense_id, jury_member_id,\ncriterion1, criterion2,\ncriterion3, criterion4)
activate DB
DB --> S : Confirmation
deactivate DB
deactivate S

Sup -> S : Submits supervisor\nevaluation (criterion 5 out of 4)
activate S
S -> DB : INSERT INTO\nsupervisor_evaluations\n(pfe_assignment_id,\nevaluator_id, criterion5)
activate DB
DB --> S : Confirmation
deactivate DB
deactivate S

== Jury deliberation ==

J -> S : Requests calculation\nof final grade
activate S
S -> S : Calculates final grade\n(sum of 5 criteria = /20)
S -> DB : UPDATE defenses\nSET final_grade = ?\nWHERE id = ?
activate DB
DB --> S : Confirmation
deactivate DB
S --> J : Displays final grade
S -> DB : INSERT INTO notifications\n(recipient_id,\ntype = 'grading_complete')
activate DB
deactivate DB
deactivate S
@enduml
